// Firebase Firestore Security Rules
// Paste ke Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: cek apakah user login
    function isAuth() {
      return request.auth != null;
    }

    // Helper: cek apakah user adalah admin
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: cek apakah user adalah parent dari student tertentu
    function isParentOf(studentId) {
      return isAuth() &&
        get(/databases/$(database)/documents/students/$(studentId)).data.parent_email == request.auth.token.email;
    }

    // ── users collection ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // ── site_settings (landing page CMS) ─────────────────────────────────
    match /site_settings/{settingId} {
      allow read: if true;           // publik — landing page baca tanpa login
      allow write: if isAdmin();
    }

    // ── students ──────────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.parent_email == request.auth.token.email);
      allow create, update, delete: if isAdmin();
    }

    // ── progress_reports ─────────────────────────────────────────────────
    match /progress_reports/{reportId} {
      allow read: if isAdmin() ||
        (isAuth() && isParentOf(resource.data.student_id));
      allow create, update, delete: if isAdmin();
    }

    // ── attendance ────────────────────────────────────────────────────────
    match /attendance/{attId} {
      allow read: if isAdmin() ||
        (isAuth() && isParentOf(resource.data.student_id));
      allow create, update, delete: if isAdmin();
    }

    // ── enrollments ───────────────────────────────────────────────────────
    match /enrollments/{enrollId} {
      allow create: if true;         // siapa saja bisa daftar dari landing page
      allow read, update, delete: if isAdmin();
    }
  }
}
